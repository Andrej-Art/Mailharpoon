# Mailharpoon Environment Configuration Example
# Copy this file to .env and adjust the values as needed.

# --- Backend Configuration ---

# Directory where machine learning models are stored
# Default: backend/models (relative to project root)
# MAILHARPOON_MODELS_DIR=/path/to/your/models

# Directory for temporary screenshots
# Default: /tmp/mailharpoon_screenshots
# MAILHARPOON_SCREENSHOT_DIR=/path/to/screenshots

# API Host and Port for the FastAPI server
# 0.0.0.0 is required for Docker/Container environments
MAILHARPOON_API_HOST=0.0.0.0
MAILHARPOON_API_PORT=8000


# --- Frontend Configuration ---

# The URL where the frontend can reach the backend API
# Change this if the backend is hosted on a different server or port
MAILHARPOON_BACKEND_URL=http://localhost:8000
